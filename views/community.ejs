<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HiveVault - Community Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 20px rgba(16, 185, 129, 0.3); } 50% { box-shadow: 0 0 40px rgba(16, 185, 129, 0.6); } }
        @keyframes slide-up { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes bounce-subtle { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
        .glass-card { background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .animate-slide-up { animation: slide-up 0.6s ease-out forwards; }
        .animate-pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
        .animate-bounce-subtle { animation: bounce-subtle 2s ease-in-out infinite; }
        input[type="text"], textarea { background: rgba(30, 41, 59, 0.5); border: 1px solid rgba(255, 255, 255, 0.1); transition: all 0.3s ease; }
        input[type="text"]:focus, textarea:focus { background: rgba(30, 41, 59, 0.8); border-color: #10b981; outline: none; box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1); }
    </style>
</head>
<body class="bg-slate-900 text-gray-100 min-h-screen">
    
    <!-- Navigation -->
    <nav class="glass-card border-b border-slate-700 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-indigo-600 rounded-lg flex items-center justify-center animate-pulse-glow">
                        <i class="fas fa-shield-alt text-white"></i>
                    </div>
                    <span class="text-2xl font-bold bg-gradient-to-r from-emerald-400 to-indigo-500 bg-clip-text text-transparent">Warrify</span>
                </div>
                <div class="flex items-center space-x-6">
                    <a href="/dashboard" class="text-gray-300 hover:text-white transition"><i class="fas fa-home mr-2"></i>Dashboard</a>
                    <a href="/add-product" class="text-gray-300 hover:text-white transition"><i class="fas fa-plus-circle mr-2"></i>Add Product</a>
                    <a href="/claim-concierge" class="text-gray-300 hover:text-white transition"><i class="fas fa-hands-helping mr-2"></i>Claims</a>
                    <a href="/sustainability" class="text-gray-300 hover:text-white transition"><i class="fas fa-leaf mr-2"></i>Sustainability</a>
                    <a href="/community" class="text-emerald-400 hover:text-emerald-300 transition"><i class="fas fa-users mr-2"></i>Community</a>
                    <div class="w-10 h-10 bg-indigo-600 rounded-full flex items-center justify-center cursor-pointer hover:bg-indigo-500 transition">
                        <i class="fas fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Header -->
        <div class="mb-8 animate-slide-up">
            <h1 class="text-4xl font-bold mb-2">Community Hub 👥</h1>
            <p class="text-gray-400">Connect, learn, and help others with DIY fixes</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Main Forum Section -->
            <div class="lg:col-span-2 space-y-6">
                
                <!-- Create Post -->
                <div class="glass-card rounded-xl p-6 animate-slide-up">
                    <h2 class="text-xl font-bold mb-4 flex items-center">
                        <i class="fas fa-pen text-indigo-400 mr-3"></i>
                        Ask the Community
                    </h2>
                    <div class="space-y-3">
                        <input type="text" id="postTitle" placeholder="What's your question or tip?" class="w-full px-4 py-3 rounded-lg text-white">
                        <textarea id="postContent" rows="3" placeholder="Describe your issue or share your solution..." class="w-full px-4 py-3 rounded-lg text-white"></textarea>
                        <div class="flex items-center space-x-3">
                            <select id="postCategory" class="flex-1 px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-white">
                                <option>DIY Fix</option>
                                <option>Troubleshooting</option>
                                <option>Maintenance Tips</option>
                                <option>Product Review</option>
                            </select>
                            <button onclick="createPost()" class="px-6 py-2 bg-gradient-to-r from-emerald-500 to-indigo-600 rounded-lg hover:from-emerald-600 hover:to-indigo-700 transition font-bold">
                                <i class="fas fa-paper-plane mr-2"></i>Post
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Forum Posts -->
                <div id="forumPosts" class="space-y-4"></div>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                
                <!-- Leaderboard -->
                <div class="glass-card rounded-xl p-6 animate-slide-up" style="animation-delay: 0.1s">
                    <h2 class="text-xl font-bold mb-4 flex items-center">
                        <i class="fas fa-trophy text-amber-400 mr-3"></i>
                        Top Mechanics
                    </h2>
                    <div id="leaderboard" class="space-y-3"></div>
                </div>

                <!-- Community Stats -->
                <div class="glass-card rounded-xl p-6 animate-slide-up" style="animation-delay: 0.2s">
                    <h2 class="text-xl font-bold mb-4 flex items-center">
                        <i class="fas fa-chart-line text-indigo-400 mr-3"></i>
                        Community Stats
                    </h2>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <span class="text-gray-400">Total Members</span>
                            <span class="text-2xl font-bold text-white" id="totalMembers">0</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-gray-400">Problems Solved</span>
                            <span class="text-2xl font-bold text-emerald-400" id="problemsSolved">0</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-gray-400">Active Today</span>
                            <span class="text-2xl font-bold text-indigo-400" id="activeToday">0</span>
                        </div>
                    </div>
                </div>

                <!-- Trending Topics -->
                <div class="glass-card rounded-xl p-6 animate-slide-up" style="animation-delay: 0.3s">
                    <h2 class="text-xl font-bold mb-4 flex items-center">
                        <i class="fas fa-fire text-orange-400 mr-3"></i>
                        Trending Topics
                    </h2>
                    <div class="space-y-2">
                        <div class="px-3 py-2 bg-slate-800 rounded-lg hover:bg-slate-700 transition cursor-pointer">
                            <p class="text-sm font-semibold">#LGErrorCodePE</p>
                            <p class="text-xs text-gray-400">45 discussions</p>
                        </div>
                        <div class="px-3 py-2 bg-slate-800 rounded-lg hover:bg-slate-700 transition cursor-pointer">
                            <p class="text-sm font-semibold">#ACMaintenance</p>
                            <p class="text-xs text-gray-400">38 discussions</p>
                        </div>
                        <div class="px-3 py-2 bg-slate-800 rounded-lg hover:bg-slate-700 transition cursor-pointer">
                            <p class="text-sm font-semibold">#WashingMachineTips</p>
                            <p class="text-xs text-gray-400">32 discussions</p>
                        </div>
                        <div class="px-3 py-2 bg-slate-800 rounded-lg hover:bg-slate-700 transition cursor-pointer">
                            <p class="text-sm font-semibold">#RefrigeratorNoise</p>
                            <p class="text-xs text-gray-400">28 discussions</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Mock Data
        const forumPosts = [
            {
                id: 1,
                author: "Priya Sharma",
                avatar: "PS",
                title: "How to fix LG Error Code PE?",
                content: "My LG washing machine is showing PE error. Water pressure seems fine. Any suggestions?",
                category: "Troubleshooting",
                replies: 12,
                likes: 24,
                solved: true,
                time: "2 hours ago",
                tags: ["LG", "Washing Machine", "Error Code"]
            },
            {
                id: 2,
                author: "Amit Patel",
                avatar: "AP",
                title: "DIY: Descaling Coffee Maker in 5 Minutes",
                content: "Here's a quick method I use to descale my Bosch coffee maker using vinegar and water...",
                category: "DIY Fix",
                replies: 8,
                likes: 45,
                solved: false,
                time: "5 hours ago",
                tags: ["Bosch", "Coffee Maker", "Maintenance"]
            },
            {
                id: 3,
                author: "Sneha Reddy",
                avatar: "SR",
                title: "Samsung TV Remote Not Working",
                content: "Tried changing batteries but still not responding. TV is only 6 months old.",
                category: "Troubleshooting",
                replies: 15,
                likes: 18,
                solved: true,
                time: "1 day ago",
                tags: ["Samsung", "TV", "Remote"]
            },
            {
                id: 4,
                author: "Rahul Mehta",
                avatar: "RM",
                title: "AC Filter Cleaning Schedule",
                content: "What's the ideal frequency for cleaning AC filters in Mumbai's humid climate?",
                category: "Maintenance Tips",
                replies: 22,
                likes: 56,
                solved: false,
                time: "1 day ago",
                tags: ["AC", "Maintenance", "Mumbai"]
            },
            {
                id: 5,
                author: "Kavita Singh",
                avatar: "KS",
                title: "Refrigerator Making Loud Noise",
                content: "My Whirlpool fridge started making a buzzing sound. Is this normal or should I call service?",
                category: "Troubleshooting",
                replies: 9,
                likes: 12,
                solved: false,
                time: "2 days ago",
                tags: ["Whirlpool", "Refrigerator", "Noise"]
            }
        ];

        const leaderboardData = [
            { rank: 1, name: "Rajesh Kumar", avatar: "RK", points: 2450, badge: "🏆", color: "amber" },
            { rank: 2, name: "Meera Joshi", avatar: "MJ", points: 1890, badge: "🥈", color: "gray" },
            { rank: 3, name: "Arjun Nair", avatar: "AN", points: 1650, badge: "🥉", color: "orange" },
            { rank: 4, name: "Pooja Desai", avatar: "PD", points: 1420, badge: "⭐", color: "indigo" },
            { rank: 5, name: "Vikram Shah", avatar: "VS", points: 1180, badge: "⭐", color: "indigo" }
        ];

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderForumPosts();
            renderLeaderboard();
            animateStats();
        });

        function renderForumPosts() {
            const container = document.getElementById('forumPosts');
            container.innerHTML = forumPosts.map((post, index) => `
                <div class="glass-card rounded-xl p-6 hover:bg-slate-800/50 transition animate-slide-up" style="animation-delay: ${index * 0.1}s; opacity: 0;">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-indigo-600 rounded-full flex items-center justify-center flex-shrink-0 font-bold">
                            ${post.avatar}
                        </div>
                        <div class="flex-1">
                            <div class="flex items-start justify-between mb-2">
                                <div>
                                    <h3 class="font-bold text-lg text-white mb-1">${post.title}</h3>
                                    <p class="text-sm text-gray-400">
                                        <span class="font-semibold text-emerald-400">${post.author}</span> • ${post.time}
                                        ${post.solved ? '<span class="ml-2 px-2 py-0.5 bg-green-500/20 text-green-400 rounded text-xs font-semibold"><i class="fas fa-check mr-1"></i>Solved</span>' : ''}
                                    </p>
                                </div>
                                <span class="px-3 py-1 bg-indigo-500/20 text-indigo-400 rounded-full text-xs font-semibold">
                                    ${post.category}
                                </span>
                            </div>
                            <p class="text-gray-300 mb-3">${post.content}</p>
                            <div class="flex flex-wrap gap-2 mb-3">
                                ${post.tags.map(tag => `<span class="px-2 py-1 bg-slate-700 text-gray-300 rounded text-xs">#${tag}</span>`).join('')}
                            </div>
                            <div class="flex items-center space-x-6 text-sm">
                                <button class="flex items-center space-x-2 text-gray-400 hover:text-emerald-400 transition">
                                    <i class="fas fa-thumbs-up"></i>
                                    <span>${post.likes}</span>
                                </button>
                                <button class="flex items-center space-x-2 text-gray-400 hover:text-indigo-400 transition">
                                    <i class="fas fa-comment"></i>
                                    <span>${post.replies} replies</span>
                                </button>
                                <button class="flex items-center space-x-2 text-gray-400 hover:text-amber-400 transition">
                                    <i class="fas fa-share"></i>
                                    <span>Share</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function renderLeaderboard() {
            const container = document.getElementById('leaderboard');
            container.innerHTML = leaderboardData.map((user, index) => `
                <div class="flex items-center justify-between p-3 bg-slate-800 rounded-lg hover:bg-slate-700 transition" style="animation: slide-up 0.5s ease-out ${index * 0.1}s forwards; opacity: 0;">
                    <div class="flex items-center space-x-3">
                        <span class="text-2xl">${user.badge}</span>
                        <div class="w-10 h-10 bg-gradient-to-br from-${user.color}-500 to-${user.color}-600 rounded-full flex items-center justify-center font-bold text-sm">
                            ${user.avatar}
                        </div>
                        <div>
                            <p class="font-semibold text-sm">${user.name}</p>
                            <p class="text-xs text-gray-400">${user.points} points</p>
                        </div>
                    </div>
                    <span class="text-lg font-bold text-${user.color}-400">#${user.rank}</span>
                </div>
            `).join('');
        }

        function animateStats() {
            animateNumber('totalMembers', 0, 2847, 2000);
            animateNumber('problemsSolved', 0, 1523, 2000);
            animateNumber('activeToday', 0, 156, 2000);
        }

        function animateNumber(id, start, end, duration) {
            const element = document.getElementById(id);
            const range = end - start;
            const increment = range / (duration / 16);
            let current = start;
            
            const timer = setInterval(() => {
                current += increment;
                if (current >= end) {
                    element.textContent = Math.round(end);
                    clearInterval(timer);
                } else {
                    element.textContent = Math.round(current);
                }
            }, 16);
        }

        function createPost() {
            const title = document.getElementById('postTitle').value;
            const content = document.getElementById('postContent').value;
            const category = document.getElementById('postCategory').value;

            if (!title || !content) {
                alert('Please fill in both title and content');
                return;
            }

            alert('Post Created! 🎉\n\nYour question has been posted to the community.\n\n✓ Category: ' + category + '\n✓ Notifications enabled\n✓ Earn points for helpful answers!\n\nThe community will respond soon.');

            // Clear form
            document.getElementById('postTitle').value = '';
            document.getElementById('postContent').value = '';
        }
    </script>
</body>
</html>
