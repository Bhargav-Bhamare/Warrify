<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Warrify - Magic Scan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes scan-line {
            0% { top: 0; opacity: 0; }
            50% { opacity: 1; }
            100% { top: 100%; opacity: 0; }
        }
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 20px rgba(16, 185, 129, 0.3); }
            50% { box-shadow: 0 0 40px rgba(16, 185, 129, 0.6); }
        }
        @keyframes slide-up {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .scan-line {
            position: absolute;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, transparent, #10b981, transparent);
            box-shadow: 0 0 20px #10b981;
            animation: scan-line 2s ease-in-out;
        }
        .glass-card {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .animate-slide-up { animation: slide-up 0.6s ease-out forwards; }
        .animate-pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
        .animate-float { animation: float 3s ease-in-out infinite; }
        .upload-zone {
            border: 2px dashed rgba(16, 185, 129, 0.3);
            transition: all 0.3s ease;
        }
        .upload-zone:hover {
            border-color: rgba(16, 185, 129, 0.6);
            background: rgba(16, 185, 129, 0.05);
        }
        .upload-zone.dragover {
            border-color: #10b981;
            background: rgba(16, 185, 129, 0.1);
            transform: scale(1.02);
        }
        input[type="text"], input[type="date"], input[type="number"], select, textarea {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        input[type="text"]:focus, input[type="date"]:focus, input[type="number"]:focus, select:focus, textarea:focus {
            background: rgba(30, 41, 59, 0.8);
            border-color: #10b981;
            outline: none;
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        }
        .field-populate {
            animation: pulse-glow 0.5s ease-in-out;
        }
    </style>
</head>
<body class="bg-slate-900 text-gray-100 min-h-screen">
    
    <!-- Navigation -->
    <nav class="glass-card border-b border-slate-700 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-indigo-600 rounded-lg flex items-center justify-center animate-pulse-glow">
                        <i class="fas fa-shield-alt text-white"></i>
                    </div>
                    <span class="text-2xl font-bold bg-gradient-to-r from-emerald-400 to-indigo-500 bg-clip-text text-transparent">HiveVault</span>
                </div>
                <div class="flex items-center space-x-6">
                    <a href="/dashboard" class="text-gray-300 hover:text-white transition"><i class="fas fa-home mr-2"></i>Dashboard</a>
                    <a href="/add-product" class="text-emerald-400 hover:text-emerald-300 transition"><i class="fas fa-plus-circle mr-2"></i>Add Product</a>
                    <a href="/claim-concierge" class="text-gray-300 hover:text-white transition"><i class="fas fa-hands-helping mr-2"></i>Claims</a>
                    <a href="/sustainability" class="text-gray-300 hover:text-white transition"><i class="fas fa-leaf mr-2"></i>Sustainability</a>
                    <a href="/community" class="text-gray-300 hover:text-white transition"><i class="fas fa-users mr-2"></i>Community</a>
                    <div class="w-10 h-10 bg-indigo-600 rounded-full flex items-center justify-center cursor-pointer hover:bg-indigo-500 transition">
                        <i class="fas fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Header -->
        <div class="mb-8 animate-slide-up text-center">
            <div class="inline-block mb-4 animate-float">
                <div class="w-20 h-20 bg-gradient-to-br from-emerald-500 to-indigo-600 rounded-2xl flex items-center justify-center">
                    <i class="fas fa-magic text-4xl text-white"></i>
                </div>
            </div>
            <h1 class="text-4xl font-bold mb-2">Magic Scan ✨</h1>
            <p class="text-gray-400">Upload your receipt and watch AI do the magic</p>
        </div>

        <!-- Upload Zone -->
        <div class="glass-card rounded-xl p-8 mb-8 animate-slide-up" style="animation-delay: 0.1s">
            <div id="uploadZone" class="upload-zone rounded-xl p-12 text-center cursor-pointer">
                <div id="uploadPrompt">
                    <i class="fas fa-cloud-upload-alt text-6xl text-emerald-400 mb-4"></i>
                    <h3 class="text-xl font-bold mb-2">Drop your receipt here</h3>
                    <p class="text-gray-400 mb-4">or click to browse</p>
                    <p class="text-sm text-gray-500">Supports: JPG, PNG, PDF • Max 10MB</p>
                    <input type="file" id="fileInput" class="hidden" accept="image/*,.pdf">
                </div>
                
                <div id="scanningAnimation" class="hidden">
                    <div class="relative inline-block">
                        <img id="receiptPreview" class="max-w-md max-h-64 rounded-lg shadow-2xl" alt="Receipt">
                        <div id="scanLine" class="scan-line"></div>
                    </div>
                    <div class="mt-6">
                        <div class="flex items-center justify-center space-x-3 mb-3">
                            <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
                            <p class="text-lg font-semibold text-emerald-400" id="scanStatus">Scanning receipt...</p>
                        </div>
                        <div class="w-64 mx-auto bg-slate-700 rounded-full h-2 overflow-hidden">
                            <div id="scanProgress" class="h-full bg-gradient-to-r from-emerald-500 to-indigo-600 rounded-full transition-all duration-300" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Form -->
        <div id="productForm" class="glass-card rounded-xl p-8 animate-slide-up opacity-50 pointer-events-none" style="animation-delay: 0.2s">
            <h2 class="text-2xl font-bold mb-6 flex items-center">
                <i class="fas fa-file-invoice text-indigo-400 mr-3"></i>
                Product Details
                <span id="aiPoweredBadge" class="ml-auto px-3 py-1 bg-emerald-500/20 text-emerald-400 rounded-full text-sm font-semibold hidden">
                    <i class="fas fa-robot mr-1"></i>AI Populated
                </span>
            </h2>
            
            <form id="assetForm" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold mb-2">Product Name *</label>
                        <input type="text" id="productName" required class="w-full px-4 py-3 rounded-lg text-white" placeholder="e.g., Samsung 55\" QLED TV">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Category *</label>
                        <select id="category" required class="w-full px-4 py-3 rounded-lg text-white">
                            <option value="">Select category</option>
                            <option value="Electronics">Electronics</option>
                            <option value="Appliances">Appliances</option>
                            <option value="Kitchen">Kitchen</option>
                            <option value="Furniture">Furniture</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Brand</label>
                        <input type="text" id="brand" class="w-full px-4 py-3 rounded-lg text-white" placeholder="e.g., Samsung">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Model Number</label>
                        <input type="text" id="modelNumber" class="w-full px-4 py-3 rounded-lg text-white" placeholder="e.g., QA55Q60AAKXXL">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Purchase Date *</label>
                        <input type="date" id="purchaseDate" required class="w-full px-4 py-3 rounded-lg text-white">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Purchase Price (₹) *</label>
                        <input type="number" id="purchasePrice" required class="w-full px-4 py-3 rounded-lg text-white" placeholder="85000">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Retailer *</label>
                        <input type="text" id="retailer" required class="w-full px-4 py-3 rounded-lg text-white" placeholder="e.g., Vijay Sales - Prabhadevi">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Invoice Number</label>
                        <input type="text" id="invoiceNumber" class="w-full px-4 py-3 rounded-lg text-white" placeholder="e.g., INV-2024-12345">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Warranty Period (Years) *</label>
                        <input type="number" id="warrantyYears" required class="w-full px-4 py-3 rounded-lg text-white" placeholder="2" min="0" max="10" step="0.5">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold mb-2">Serial Number</label>
                        <input type="text" id="serialNumber" class="w-full px-4 py-3 rounded-lg text-white" placeholder="Optional">
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold mb-2">Additional Notes</label>
                    <textarea id="notes" rows="3" class="w-full px-4 py-3 rounded-lg text-white" placeholder="Any additional information about this product..."></textarea>
                </div>
                
                <div class="flex items-center space-x-4 pt-4">
                    <button type="submit" class="flex-1 px-6 py-4 bg-gradient-to-r from-emerald-500 to-indigo-600 rounded-lg hover:from-emerald-600 hover:to-indigo-700 transition font-bold text-lg">
                        <i class="fas fa-save mr-2"></i>Save to Vault
                    </button>
                    <button type="button" onclick="window.location.href='/dashboard'" class="px-6 py-4 bg-slate-700 hover:bg-slate-600 rounded-lg transition">
                        Cancel
                    </button>
                </div>
            </form>
        </div>

        <!-- Success Modal -->
        <div id="successModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">
            <div class="glass-card rounded-2xl p-8 max-w-md mx-4 text-center animate-slide-up">
                <div class="w-20 h-20 bg-gradient-to-br from-emerald-500 to-indigo-600 rounded-full flex items-center justify-center mx-auto mb-4 animate-pulse-glow">
                    <i class="fas fa-check text-4xl text-white"></i>
                </div>
                <h3 class="text-2xl font-bold mb-2">Asset Added Successfully! 🎉</h3>
                <p class="text-gray-400 mb-6">Your product has been secured in the vault</p>
                <div class="flex space-x-3">
                    <button onclick="window.location.href='/dashboard'" class="flex-1 px-6 py-3 bg-gradient-to-r from-emerald-500 to-indigo-600 rounded-lg hover:from-emerald-600 hover:to-indigo-700 transition">
                        View Dashboard
                    </button>
                    <button onclick="location.reload()" class="flex-1 px-6 py-3 bg-slate-700 hover:bg-slate-600 rounded-lg transition">
                        Add Another
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>

        // Mock OCR Data - Simulates AI extraction
        const mockOCRData = {
            productName: "Samsung 55\" QLED 4K Smart TV",
            category: "Electronics",
            brand: "Samsung",
            modelNumber: "QA55Q60AAKXXL",
            purchaseDate: "2024-01-15",
            purchasePrice: "85000",
            retailer: "Vijay Sales - Prabhadevi, Mumbai",
            invoiceNumber: "VS-MUM-2024-45678",
            warrantyYears: "2",
            serialNumber: "SN123456789"
        };

        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');
        const uploadPrompt = document.getElementById('uploadPrompt');
        const scanningAnimation = document.getElementById('scanningAnimation');
        const productForm = document.getElementById('productForm');
        const assetForm = document.getElementById('assetForm');

        // Upload Zone Click
        uploadZone.addEventListener('click', () => {
            if (!scanningAnimation.classList.contains('hidden')) return;
            fileInput.click();
        });

        // File Selection
        fileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                handleFileUpload(file);
            }
        });

        // Drag and Drop
        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('dragover');
        });

        uploadZone.addEventListener('dragleave', () => {
            uploadZone.classList.remove('dragover');
        });

        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('dragover');
            const file = e.dataTransfer.files[0];
            if (file) {
                handleFileUpload(file);
            }
        });

        function handleFileUpload(file) {
            // Show preview
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('receiptPreview').src = e.target.result;
                uploadPrompt.classList.add('hidden');
                scanningAnimation.classList.remove('hidden');
                
                // Start scanning animation
                startScanAnimation();
            };
            reader.readAsDataURL(file);
        }

        function startScanAnimation() {
            const scanStatus = document.getElementById('scanStatus');
            const scanProgress = document.getElementById('scanProgress');
            const scanLine = document.getElementById('scanLine');
            
            let progress = 0;
            const stages = [
                { progress: 20, text: 'Analyzing receipt...', delay: 500 },
                { progress: 40, text: 'Detecting text fields...', delay: 800 },
                { progress: 60, text: 'Extracting product info...', delay: 1000 },
                { progress: 80, text: 'Validating data...', delay: 1200 },
                { progress: 100, text: 'Complete! ✓', delay: 1500 }
            ];
            
            let currentStage = 0;
            
            function updateStage() {
                if (currentStage < stages.length) {
                    const stage = stages[currentStage];
                    scanProgress.style.width = stage.progress + '%';
                    scanStatus.textContent = stage.text;
                    
                    if (stage.progress === 100) {
                        scanStatus.classList.remove('text-emerald-400');
                        scanStatus.classList.add('text-green-400');
                        setTimeout(() => {
                            populateForm();
                        }, 500);
                    }
                    
                    currentStage++;
                    if (currentStage < stages.length) {
                        setTimeout(updateStage, stages[currentStage - 1].delay);
                    }
                }
            }
            
            // Trigger scan line animation
            scanLine.style.animation = 'none';
            setTimeout(() => {
                scanLine.style.animation = 'scan-line 2s ease-in-out';
            }, 10);
            
            updateStage();
        }

        function populateForm() {
            // Enable form
            productForm.classList.remove('opacity-50', 'pointer-events-none');
            document.getElementById('aiPoweredBadge').classList.remove('hidden');
            
            // Populate fields with animation
            const fields = [
                { id: 'productName', value: mockOCRData.productName, delay: 100 },
                { id: 'category', value: mockOCRData.category, delay: 200 },
                { id: 'brand', value: mockOCRData.brand, delay: 300 },
                { id: 'modelNumber', value: mockOCRData.modelNumber, delay: 400 },
                { id: 'purchaseDate', value: mockOCRData.purchaseDate, delay: 500 },
                { id: 'purchasePrice', value: mockOCRData.purchasePrice, delay: 600 },
                { id: 'retailer', value: mockOCRData.retailer, delay: 700 },
                { id: 'invoiceNumber', value: mockOCRData.invoiceNumber, delay: 800 },
                { id: 'warrantyYears', value: mockOCRData.warrantyYears, delay: 900 },
                { id: 'serialNumber', value: mockOCRData.serialNumber, delay: 1000 }
            ];
            
            fields.forEach(field => {
                setTimeout(() => {
                    const element = document.getElementById(field.id);
                    element.value = field.value;
                    element.classList.add('field-populate');
                    
                    // Scroll to form
                    if (field.delay === 100) {
                        productForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                    
                    setTimeout(() => {
                        element.classList.remove('field-populate');
                    }, 500);
                }, field.delay);
            });
        }

        // Form Submission
        assetForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Collect form data
            const formData = {
                productName: document.getElementById('productName').value,
                category: document.getElementById('category').value,
                brand: document.getElementById('brand').value,
                modelNumber: document.getElementById('modelNumber').value,
                purchaseDate: document.getElementById('purchaseDate').value,
                purchasePrice: document.getElementById('purchasePrice').value,
                retailer: document.getElementById('retailer').value,
                invoiceNumber: document.getElementById('invoiceNumber').value,
                warrantyYears: document.getElementById('warrantyYears').value,
                serialNumber: document.getElementById('serialNumber').value,
                notes: document.getElementById('notes').value
            };
            
            // In production, send to backend API
            console.log('Saving asset:', formData);
            
            // Show success modal
            document.getElementById('successModal').classList.remove('hidden');
        });

        // Quick Tips
        setTimeout(() => {
            if (uploadPrompt && !uploadPrompt.classList.contains('hidden')) {
                const tips = [
                    "💡 Tip: Clear photos work best!",
                    "💡 Tip: PDF invoices are supported too!",
                    "💡 Tip: Our AI can read handwritten receipts!"
                ];
                const randomTip = tips[Math.floor(Math.random() * tips.length)];
                
                const tipElement = document.createElement('div');
                tipElement.className = 'mt-4 text-sm text-emerald-400 animate-pulse';
                tipElement.textContent = randomTip;
                uploadPrompt.appendChild(tipElement);
            }
        }, 3000);
    </script>
</body>
</html>
